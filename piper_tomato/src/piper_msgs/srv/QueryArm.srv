# === Request ===

uint8 command_type
uint8 GET_CURRENT_JOINTS=13
uint8 GET_CURRENT_POSE=14

# 通用数值参数
float64[] values

---

# === Response ===

bool success
string message
int32 error_code

# 通用位姿字段
float64 cur_x
float64 cur_y
float64 cur_z
float64 cur_roll
float64 cur_pitch
float64 cur_yaw

# 标准位姿字段
geometry_msgs/Pose cur_pose

# 当前关节角列表
float64[] cur_joint
