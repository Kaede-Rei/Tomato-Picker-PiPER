# === Goal ===

uint8 command_type
uint8 HOME=1
uint8 MOVE_JOINTS=2
uint8 MOVE_TARGET=3
uint8 MOVE_TARGET_IN_EEF_FRAME=4
uint8 TELESCOPIC_END=5
uint8 ROTATE_END=6
uint8 MOVE_LINE=7
uint8 MOVE_BEZIER=8
uint8 MOVE_DECARTES=9
uint8 MOVE_TO_ZERO=15

# 通用位姿字段
uint8 target_type
uint8 TARGET_POSE=0
uint8 TARGET_POINT=1
uint8 TARGET_ORIENTATION=2
float64[] x
float64[] y
float64[] z
float64[] roll
float64[] pitch
float64[] yaw

# 目标关节名称
string[] joint_names

# 关节目标
float64[] joints

# 通用数值参数
float64[] values

---

# === Result ===

bool success
string message
int32 error_code

# 通用位姿字段
float64 cur_x
float64 cur_y
float64 cur_z
float64 cur_roll
float64 cur_pitch
float64 cur_yaw

# 当前关节角列表
float64[] cur_joint

# 通用数值参数
float64[] values

---

# === Feedback ===

string stage
float64 progress
string message
